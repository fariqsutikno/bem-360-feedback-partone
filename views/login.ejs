<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Portal BEM STDIIS</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <link href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css" rel="stylesheet">
    
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f3f4f6; }
        /* Animasi halu dikit biar keren */
        .fade-in { animation: fadeIn 0.5s ease-in; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body class="h-screen flex items-center justify-center p-4 fade-in">

    <div class="bg-white p-8 md:p-10 rounded-3xl shadow-xl w-full max-w-md border border-gray-100">
        
        <div class="text-center mb-8">
            <div class="bg-blue-100 w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4 text-blue-600 text-2xl shadow-sm">
                👋
            </div>
            <h1 class="text-3xl font-bold text-gray-800 tracking-tight">Login Portal BEM STDIIS</h1>
            <p class="text-gray-400 text-sm mt-2">Portal Terpusat BEM STDIIS Kabinet Gema Revolusi</p>
        </div>

        <% if(error) { %>
            <div class="bg-red-50 border-l-4 border-red-500 text-red-600 px-4 py-3 rounded-r-xl mb-6 text-sm shadow-sm flex items-center">
                <span class="mr-2">⚠️</span>
                <%= error %>
            </div>
        <% } %>

        <form action="/login" method="POST">
            <div class="mb-6">
                <label class="block text-gray-700 text-xs font-bold mb-2 uppercase tracking-wider ml-1">Username</label>
                <input type="text" name="nim" placeholder="Masukkan Username" 
                       class="w-full px-4 py-4 rounded-xl bg-gray-50 border border-gray-200 focus:border-blue-500 focus:bg-white focus:ring-4 focus:ring-blue-500/20 transition outline-none text-gray-700 font-medium placeholder-gray-400" required>
            </div>

            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-xl transition shadow-lg shadow-blue-500/40 transform hover:-translate-y-1">
                Masuk Dashboard 🚀
            </button>
        </form>

        <div class="mt-8 text-center border-t border-gray-100 pt-6">
            <p class="text-gray-400 text-xs">
                &copy; 2025 | Biro Pengembangan & Penjaminan Mutu BEM STDIIS
            </p>
        </div>
    </div>

</body>
</html>