<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - BEM Feedback</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #F3F4F6; }
        .fade-in { animation: fadeIn 0.5s ease-in; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body class="p-6 md:p-10 fade-in">

    <div class="flex justify-between items-center mb-8">
        <div>
            <h1 class="text-3xl font-bold text-gray-800">Ahlan, <%= me.name %>! 👋</h1>
            
            <% 
                const namaKementerian = {
                    'inti': 'Pengurus Inti (BPH)',
                    'admin': 'Biro Administrasi',
                    'ppm': 'Biro Pengembangan & Penjaminan Mutu',
                    'penkeu': 'Biro Pengelolaan Keuangan',
                    'inkeu': 'Biro Inovasi Keuangan',
                    'dikrir': 'Kementerian Akademik & Pengembangan Karir',
                    'kpsdm': 'Kementerian Kaderisasi & Pengembangan SDM',
                    'pemora': 'Kementerian Pemuda & Olahraga',
                    'adkesma': 'Kementerian Advokasi & Kesejahteraan Mahasiswa',
                    'pengbas': 'Kementerian Pengembangan Bahasa',
                    'hubeks': 'Kementerian Hubungan Eksternal',
                    'harkam': 'Kementerian Harmonisasi Kampus',
                    'dkv': 'Biro Desain Komunikasi Visual'
                };

                const labelDept = namaKementerian[me.dept] || 'Kementerian ' + me.dept.toUpperCase();
            %>

            <p class="text-gray-500 mt-1 text-sm font-medium flex items-center gap-2">
                <span class="bg-blue-100 text-blue-700 px-2 py-0.5 rounded text-xs font-bold uppercase tracking-wider">
                    <%= me.role %>
                </span> 
                <span class="text-gray-300">|</span>
                <span class="text-gray-600 font-semibold">
                    <%= labelDept %>
                </span>
            </p>
        </div>
        
        <a href="/logout" class="bg-white px-4 py-2 rounded-xl shadow-sm hover:shadow-md text-red-500 font-bold transition border border-gray-100 text-sm flex items-center gap-2">
            Logout 🚪
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <div class="bg-white p-6 rounded-3xl shadow-sm col-span-1 border-l-4 border-blue-500">
            <h3 class="font-bold text-lg text-gray-800 mb-2">Refleksi Diri 🪞</h3>
            
            <% if(isReflectionDone) { %>
                <div class="bg-green-50 text-green-700 p-4 rounded-xl text-sm font-bold flex items-center gap-2 border border-green-100">
                    <span>✅</span> Sudah Mengisi Refleksi
                </div>
            <% } else { %>
                <p class="text-gray-500 text-sm mb-4">
                    Sebelum menilai orang lain, nilai diri sendiri dulu yuk! Data ini penting buat evaluasi kinerja.
                </p>
                <a href="/reflection" class="block w-full text-center bg-blue-50 text-blue-600 font-bold py-3 rounded-xl hover:bg-blue-100 transition">
                    Isi Refleksi
                </a>
            <% } %>
        </div>

        <div class="bg-white p-6 rounded-3xl shadow-sm col-span-1 md:col-span-2">
            <h3 class="font-bold text-lg text-gray-800 mb-2">Misi Evaluasi Kamu 🎯</h3>
            <p class="text-gray-400 text-sm mb-4">Selesaikan semua penilaian rekan kerja & atasanmu.</p>
            
            <% 
                const totalTasks = todoList.length;
                const doneTasks = todoList.filter(u => u.status === 'DONE').length;
                const progress = totalTasks > 0 ? (doneTasks / totalTasks) * 100 : 0;
            %>
            <div class="w-full bg-gray-100 rounded-full h-4 mb-2">
                <div class="bg-blue-500 h-4 rounded-full transition-all duration-1000" style="width: <%= progress %>%"></div>
            </div>
            <div class="flex justify-between text-xs text-gray-500">
                <span><%= doneTasks %> Selesai</span>
                <span>Total <%= totalTasks %> Orang</span>
            </div>
        </div>

        <div class="bg-white p-6 rounded-3xl shadow-sm col-span-1 md:col-span-3">
            <h3 class="font-bold text-lg text-gray-800 mb-6">Daftar Rekan & Atasan</h3>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                <% if(todoList.length === 0) { %>
                    <p class="text-gray-400 italic col-span-3 text-center">Wah, belum ada daftar orang yang harus dinilai.</p>
                <% } %>

                <% todoList.forEach(user => { %>
                    <div class="border border-gray-100 p-4 rounded-2xl flex items-center justify-between hover:border-blue-200 transition bg-gray-50">
                        <div class="flex items-center space-x-3">
                            <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-white shadow-sm <%= user.status === 'DONE' ? 'bg-green-400' : 'bg-gray-400' %>">
                                <%= user.name.charAt(0) %>
                            </div>
                            <div>
                                <h4 class="font-bold text-gray-800 text-sm"><%= user.name %></h4>
                                <p class="text-[10px] text-gray-500 uppercase tracking-wide font-bold"><%= user.role %></p>
                            </div>
                        </div>
                        
                        <% if (user.status === 'PENDING') { %>
                            <a href="/rate/<%= user.nim %>" class="bg-white border border-gray-200 text-gray-700 px-4 py-2 rounded-xl text-xs font-bold hover:bg-blue-600 hover:text-white transition shadow-sm">
                                Nilai ➔
                            </a>
                        <% } else { %>
                            <span class="text-green-600 bg-green-50 border border-green-100 px-3 py-1 rounded-lg text-xs font-bold">✅ Selesai</span>
                        <% } %>
                    </div>
                <% }) %>
            </div>
        </div>

    </div>
</body>
</html>